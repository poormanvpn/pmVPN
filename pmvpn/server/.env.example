# PMVPN Server Configuration
# Copy to .env and edit

# Base port — all 8 services offset from this (2200-2207)
PMVPN_BASE_PORT=2200

# Bind address
PMVPN_HOST=0.0.0.0

# Wallet-to-user mapping (format: 0xaddress:username,0xaddress:username)
WALLET_USER_MAP=0xYourWalletAddress:yourusername

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Shell binary for PTY sessions
PMVPN_SHELL=/bin/bash

# Base directory for user home dirs
PMVPN_HOME_BASE=/home
